# gwon.my (절대 건드리지 않음)
gwon.my {
  handle /backend* {
    reverse_proxy gwon-backend-1:8080
  }

  handle /ws* {
    reverse_proxy gwon-backend-1:8080 {
      transport http {
        versions 1.1
      }
      header_up Connection {>Connection}
      header_up Upgrade {>Upgrade}
    }
  }

  handle {
    reverse_proxy gwon-frontend-1:3000
  }
}

# move.io.kr
move.io.kr {
  root * /srv/move
  file_server
  encode zstd gzip
  try_files {path} /index.html

  handle /backend* {
    reverse_proxy move-backend-1:8080
  }

  handle /ws* {
    reverse_proxy move-backend-1:8080 {
      transport http {
        versions 1.1
      }
      header_up Connection {>Connection}
      header_up Upgrade {>Upgrade}
    }
  }
}

