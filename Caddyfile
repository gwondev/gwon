# gwon.my
gwon.my {
  # /backend → Spring Boot
  handle /backend* {
    reverse_proxy backend:8080
  }

  # Spring Boot WebSocket
  handle /ws* {
    reverse_proxy backend:8080 {
      transport http {
        versions 1.1
      }
    }
  }

  # 그 외 → 프론트엔드
  handle {
    reverse_proxy frontend:3000
  }
}

# move.io.kr
move.io.kr {
  # React 빌드 산출물(dist) 서빙
  root * /home/gwon/move/frontend/dist
  file_server
  encode zstd gzip

  # Spring Boot API
  handle /backend* {
    reverse_proxy move-backend:8080
  }

  # Spring Boot WebSocket
  handle /ws* {
    reverse_proxy move-backend:8080 {
      transport http {
        versions 1.1
      }
    }
  }
}
