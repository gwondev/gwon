gwon.my {
  # /backend 경로부터는 그대로 Spring으로 전달
  handle /backend* {
    reverse_proxy backend:8080
  }

  # Spring Boot WebSocket
    handle /ws* {
      reverse_proxy backend:8080 {
        transport http {
          versions 1.1
        }
      }
    }

  # 그 외는 프론트
  handle {
    reverse_proxy frontend:3000
  }
}


