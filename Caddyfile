# gwon.my (절대 건드리지 않음)
gwon.my {
  handle /backend* {
    reverse_proxy gwon-backend-1:8080
  }

  handle /ws* {
    reverse_proxy gwon-backend-1:8080 {
      transport http {
        versions 1.1
      }
      header_up Connection {>Connection}
      header_up Upgrade {>Upgrade}
    }
  }

  handle {
    reverse_proxy gwon-frontend-1:3000
  }
}

# move.io.kr
move.io.kr {

  # ✅ 1️⃣ WebSocket → Spring Boot 백엔드로
  handle /ws* {
    reverse_proxy move-backend-1:8080 {
      transport http {
        versions 1.1
      }
      header_up Connection {>Connection}
      header_up Upgrade {>Upgrade}
    }
  }

  # ✅ 2️⃣ API 요청 → Spring Boot 백엔드로
  handle /backend* {
    reverse_proxy move-backend-1:8080
  }

  # ✅ 3️⃣ 정적 파일 (React build 결과물)
  root * /srv/move
  file_server
  encode zstd gzip

  # ✅ 4️⃣ React SPA 라우팅 fallback
  try_files {path} /index.html
}

